# Backend Environment Variables
# Copy this file to .env and fill in the values.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── Email provider ────────────────────────────────────────────────────────────
# "smtp"   → SendIX own SMTP server (production target — Phase 5)
# "resend" → Resend API              (fallback / development default)
EMAIL_PROVIDER=resend

# ── Resend (fallback / legacy) ────────────────────────────────────────────────
RESEND_API_KEY=your_resend_api_key

# ── SMTP own server ───────────────────────────────────────────────────────────
# Only required when EMAIL_PROVIDER=smtp.
#
# Options:
#   • Self-hosted Postfix / Exim on a dedicated IP
#   • Mailgun SMTP relay     smtp.mailgun.org:587
#   • Amazon SES SMTP relay  email-smtp.<region>.amazonaws.com:587
#   • Brevo (Sendinblue)     smtp-relay.brevo.com:587
#
SMTP_HOST=smtp.yourdomain.com
SMTP_PORT=587
SMTP_SECURE=false         # true = implicit TLS (port 465), false = STARTTLS (port 587)
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM_DOMAIN=sendix.com
SMTP_FROM_NAME=SendIX

# ── DKIM signing ──────────────────────────────────────────────────────────────
# Strongly recommended for inbox delivery. Skip in dev, required in prod.
#
# Generate keys:
#   openssl genrsa -out dkim-private.pem 2048
#   openssl rsa -in dkim-private.pem -pubout -out dkim-public.pem
#
# Paste private key as a single line with literal \n (not real newlines).
#
SMTP_DKIM_DOMAIN=sendix.com
SMTP_DKIM_SELECTOR=sendix
SMTP_DKIM_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIIEvQ...\n-----END PRIVATE KEY-----

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_AGENCY=price_...
STRIPE_WEBHOOK_SECRET=whsec_...
